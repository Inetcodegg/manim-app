# Copy this file to `.env` and fill in the SAME values the Manim Studio
# website uses for NEXT_PUBLIC_FIREBASE_* (see that repo's .env.example) —
# these are public web-app credentials, not secrets, and pointing this app
# at the identical Firebase project is what makes "sign in with your
# Manim Studio account" work. Run `npm run generate-firebase-config` after
# filling this in (also runs automatically as part of `npm run build`).

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Base URL of the Manim Studio website's API (for /api/notifications and
# /api/auth/profile). Point this at the deployed site normally; only
# change it if you're testing against a local `npm run dev` of the website.
SITE_API_BASE=https://manim-std.vercel.app

# Optional: repository "owner/name" electron-updater checks for new
# releases (GitHub Releases). Leave unset to disable auto-update checks.
UPDATE_REPO=
