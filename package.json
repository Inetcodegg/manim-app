{
  "name": "manim-studio-render-agent",
  "productName": "Manim Studio Render Agent",
  "version": "1.1.4",
  "description": "Local render agent for Manim Studio — runs Manim on your own machine and connects to manim-std.vercel.app over a local WebSocket.",
  "private": true,
  "main": "dist/main/index.js",
  "author": "Manim Studio",
  "license": "UNLICENSED",
  "scripts": {
    "build": "node scripts/generate-firebase-config.js && tsc -p tsconfig.build.json && node scripts/bundle-renderer.js && node scripts/copy-static.js",
    "watch": "tsc -p tsconfig.build.json --watch",
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"npm:watch\" \"npm run start:wait\"",
    "start:wait": "wait-on dist/main/index.js && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepare-runtime": "node scripts/prepare-runtime.js",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-firebase-config": "node scripts/generate-firebase-config.js",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "firebase": "^12.16.0",
    "node-forge": "^1.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-forge": "^1.3.14",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.manimstudio.renderagent",
    "productName": "Manim Studio Render Agent",
    "artifactName": "Manim-Studio-Render-Agent-Setup-${version}.exe",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "license": "build/license.txt",
      "warningsAsErrors": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Education"
    }
  }
}
